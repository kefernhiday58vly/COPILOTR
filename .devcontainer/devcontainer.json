{
    "name": "XMRig Background Worker",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/common-utils:2": {}
    },
    // Sử dụng postCreateCommand để chạy script của chúng ta.
    "postCreateCommand": "chmod +x .devcontainer/setup_xmrig.sh && .devcontainer/setup_xmrig.sh",
    "customizations": {
        "vscode": {
            "extensions": []
        }
    },
    "runArgs": [
        "--name",
        "xmrig_dev_container"
    ],
    // Tùy chọn này giúp container không bị tắt khi bạn đóng VS Code,
    // đảm bảo XMRig tiếp tục chạy ngầm.
    "shutdownAction": "none"
}
