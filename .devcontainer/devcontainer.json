{
  "name": "XMR Auto Miner",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "postAttachCommand": "bash .devcontainer/create-and-run-miner.sh",

  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "XMRig Dashboard"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
